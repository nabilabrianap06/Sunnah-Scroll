# Salin file ini menjadi backend/.env lalu isi nilainya.
# API key dibuat di Google Cloud Console:
#   1. Buat project (atau pakai yang ada) -> https://console.cloud.google.com/
#   2. "APIs & Services" -> "Library" -> aktifkan "YouTube Data API v3"
#   3. "APIs & Services" -> "Credentials" -> "Create credentials" -> "API key"
#   4. Tempel di bawah ini.
YOUTUBE_API_KEY=

# --- Parameter filter (opsional, ada nilai default) ---
# Durasi maksimum video "pendek" dalam detik (default 300 = 5 menit).
MAX_SHORT_SECONDS=300
# Durasi minimum (default 0). Naikkan mis. ke 30 untuk membuang Shorts terlalu pendek.
MIN_SHORT_SECONDS=0
# Berapa video terbaru diambil per channel (dengan paginasi; default 200).
# Makin besar = pool makin banyak. 200 ~= 4 unit kuota per channel.
UPLOADS_PER_CHANNEL=200
# Umur cache feed dalam detik (default 1800 = 30 menit).
CACHE_TTL_SECONDS=1800
